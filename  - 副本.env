# App
APP_NAME=A-Share Research Assistant API
APP_VERSION=0.1.0
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
API_PREFIX=

# Database
SQLITE_URL=sqlite:///./app.db
DUCKDB_PATH=./data/market.duckdb

# OpenAI
OPENAI_API_KEY=1049082a-13f6-465c-9149-b66a6d7c523a
OPENAI_MODEL=doubao-seed-2.0-pro
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
ENABLE_LLM_DEBATE=true
LLM_DEBATE_TIMEOUT_SECONDS=20

# Data source toggles
ENABLE_AKSHARE=true
ENABLE_BAOSTOCK=true
ENABLE_CNINFO=true
ENABLE_MOOTDX=false
ENABLE_EASTMONEY=true
MOOTDX_TDX_DIR=D:/new_tdx

# Cache
CACHE_DIR=./cache
DATA_DIR=./data

# Scheduling
RUN_DAILY_SCAN=false
RUN_REVIEW_JOBS=false

# Data refresh and provider tuning
DATA_REFRESH_DAILY_BAR_LOOKBACK_DAYS=400
DATA_REFRESH_ANNOUNCEMENT_LOOKBACK_DAYS=90
DATA_REFRESH_ANNOUNCEMENT_LIMIT=2000
DATA_REFRESH_PROGRESS_LOG_INTERVAL=50
DATA_REFRESH_SYMBOL_SLEEP_MS=120
AKSHARE_DAILY_RETRY_MAX_ATTEMPTS=4
AKSHARE_DAILY_RETRY_BACKOFF_SECONDS=0.8
AKSHARE_DAILY_RETRY_JITTER_SECONDS=0.2
