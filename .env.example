# App
APP_NAME=A-Share Research Assistant API
APP_VERSION=0.1.0
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
API_PREFIX=

# Database
SQLITE_URL=sqlite:///./app.db
DUCKDB_PATH=./data/market.duckdb

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4

# Data source toggles
ENABLE_AKSHARE=true
ENABLE_BAOSTOCK=true
ENABLE_CNINFO=true
ENABLE_EASTMONEY=true

# Cache
CACHE_DIR=./cache
DATA_DIR=./data

# Scheduling
RUN_DAILY_SCAN=false
RUN_REVIEW_JOBS=false
